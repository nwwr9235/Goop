# ══════════════════════════════════════════════════════════════════
#  ArabBot — متغيرات البيئة
#  انسخ هذا الملف إلى .env وأدخل بياناتك
#  على Railway: أضف هذه المتغيرات في Variables tab
# ══════════════════════════════════════════════════════════════════

# ── Telegram Bot (من @BotFather) ──────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Telegram App (من https://my.telegram.org/apps) ───────────────
API_ID=12345678
API_HASH=your_api_hash_here

# ── معرّفك الشخصي (Owner) ─────────────────────────────────────────
OWNER_ID=123456789

# ── مستخدمون بصلاحيات عليا (اختياري - مفصول بمسافة) ─────────────
SUDO_USERS=

# ── MongoDB ───────────────────────────────────────────────────────
# على Railway: أضف MongoDB plugin → سيُضاف MONGO_URL تلقائياً
# أو استخدم MongoDB Atlas:
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/arabbot
# MONGO_URI=mongodb://localhost:27017   ← للتشغيل المحلي

# اسم قاعدة البيانات
DB_NAME=arabbot

# ── إعدادات الموسيقى ──────────────────────────────────────────────
MAX_QUEUE_SIZE=50
DOWNLOAD_DIR=/tmp/arabbot_music

# ── نظام الإنذارات ────────────────────────────────────────────────
MAX_WARNINGS=3
# الإجراء عند تجاوز الحد: mute أو ban
WARN_ACTION=mute

# ── قناة السجلات (اختياري) ───────────────────────────────────────
LOG_CHANNEL=0
